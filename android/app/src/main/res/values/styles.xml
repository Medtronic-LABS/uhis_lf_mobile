<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Splash theme — shown while Flutter engine loads. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Normal theme applied once Flutter is running.
         Uses a Material parent so Android 12+ edge-to-edge window insets
         are respected. Transparent background lets Flutter own the entire
         window surface including behind status bar and navigation bar. -->
    <style name="NormalTheme" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources>
